{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prophet.local/schemas/sandbox-artifact.v0.1.json",
  "title": "Prophet Sandbox Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "generated_at",
    "schema_version",
    "input_refs",
    "predicted_exploit",
    "defense",
    "validation",
    "operator_notes",
    "audit",
    "source_refs"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^ee-sandbox-[A-Za-z0-9_.-]+$"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "schema_version": {
      "const": "exploit_engine_artifact.v0.1"
    },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "forecast_id",
        "vector_id"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "forecast_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "vector_id": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "predicted_exploit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exploit_class_label",
        "cwe_ids",
        "cve_id",
        "kev_listed",
        "epss_score",
        "attack_technique",
        "non_actionable_rationale",
        "confidence",
        "confidence_score"
      ],
      "properties": {
        "exploit_class_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cwe_ids": {
          "$ref": "#/$defs/string_array"
        },
        "cve_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/non_empty_string"
            },
            {
              "type": "null"
            }
          ]
        },
        "kev_listed": {
          "type": "boolean"
        },
        "epss_score": {
          "anyOf": [
            {
              "$ref": "#/$defs/unit_number"
            },
            {
              "type": "null"
            }
          ]
        },
        "attack_technique": {
          "anyOf": [
            {
              "$ref": "#/$defs/non_empty_string"
            },
            {
              "type": "null"
            }
          ]
        },
        "non_actionable_rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "confidence_score": {
          "$ref": "#/$defs/unit_number"
        }
      }
    },
    "defense": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patch",
        "sigma_rule"
      ],
      "properties": {
        "patch": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "patch_format",
            "diff",
            "applies_to",
            "rollback_note"
          ],
          "properties": {
            "summary": {
              "$ref": "#/$defs/non_empty_string"
            },
            "patch_format": {
              "enum": [
                "unified_diff",
                "config_snippet",
                "jvm_flag_set"
              ]
            },
            "diff": {
              "$ref": "#/$defs/non_empty_string"
            },
            "applies_to": {
              "$ref": "#/$defs/non_empty_string"
            },
            "rollback_note": {
              "$ref": "#/$defs/non_empty_string"
            }
          }
        },
        "sigma_rule": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rule_id",
            "title",
            "yaml",
            "level",
            "logsources"
          ],
          "properties": {
            "rule_id": {
              "$ref": "#/$defs/non_empty_string"
            },
            "title": {
              "$ref": "#/$defs/non_empty_string"
            },
            "yaml": {
              "$ref": "#/$defs/non_empty_string"
            },
            "level": {
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            },
            "logsources": {
              "$ref": "#/$defs/string_array"
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_id",
        "scope",
        "pre_patch_status",
        "pre_patch_excerpt",
        "post_patch_status",
        "post_patch_excerpt",
        "validation_tool",
        "validation_template",
        "wall_time_seconds"
      ],
      "properties": {
        "sandbox_id": {
          "const": "localhost-fixture-harness"
        },
        "scope": {
          "type": "string",
          "pattern": "localhost only"
        },
        "pre_patch_status": {
          "enum": [
            "vulnerable",
            "not_vulnerable",
            "error"
          ]
        },
        "pre_patch_excerpt": {
          "$ref": "#/$defs/non_empty_string"
        },
        "post_patch_status": {
          "enum": [
            "vulnerable",
            "not_vulnerable",
            "blocked",
            "error"
          ]
        },
        "post_patch_excerpt": {
          "$ref": "#/$defs/non_empty_string"
        },
        "validation_tool": {
          "const": "prophet deterministic sandbox runner"
        },
        "validation_template": {
          "anyOf": [
            {
              "$ref": "#/$defs/non_empty_string"
            },
            {
              "type": "null"
            }
          ]
        },
        "wall_time_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "operator_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_gate_decision",
        "operator_label",
        "post_run_caveats"
      ],
      "properties": {
        "human_gate_decision": {
          "enum": [
            "approved",
            "denied",
            "bypassed_for_fixture"
          ]
        },
        "operator_label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "post_run_caveats": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "signed_sha256",
        "emitted_by"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "signed_sha256": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "emitted_by": {
          "const": "sandbox_runner.fixture"
        },
        "policy_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "retention": {
          "type": "object"
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "url",
          "supports"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/non_empty_string"
          },
          "label": {
            "$ref": "#/$defs/non_empty_string"
          },
          "url": {
            "$ref": "#/$defs/non_empty_string"
          },
          "supports": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unit_number": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
