{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prophet.local/schemas/prophet-pilot-policy.v0.1.json",
  "title": "Prophet Pilot Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "description",
    "allowed_modes",
    "controls",
    "required_attestations",
    "retention"
  ],
  "properties": {
    "schema_version": {
      "const": "prophet_pilot_policy.v0.1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,120}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "allowed_modes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_context",
        "osint_collection",
        "forecast_generation",
        "validation",
        "evidence_generation"
      ],
      "properties": {
        "asset_context": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "fixture",
              "customer_owned_metadata"
            ]
          }
        },
        "osint_collection": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "fixture",
              "seeded_osint"
            ]
          }
        },
        "forecast_generation": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "fixture",
              "seeded_osint"
            ]
          }
        },
        "validation": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "fixture",
              "localhost_sandbox"
            ]
          }
        },
        "evidence_generation": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "fixture",
              "localhost_sandbox"
            ]
          }
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_targets_allowed",
        "live_vm_scraper_allowed",
        "arbitrary_target_input_allowed",
        "payload_generation_allowed",
        "raw_scraper_text_allowed",
        "private_hostnames_allowed",
        "credentials_allowed"
      ],
      "properties": {
        "live_targets_allowed": {
          "const": false
        },
        "live_vm_scraper_allowed": {
          "const": false
        },
        "arbitrary_target_input_allowed": {
          "const": false
        },
        "payload_generation_allowed": {
          "const": false
        },
        "raw_scraper_text_allowed": {
          "const": false
        },
        "private_hostnames_allowed": {
          "const": false
        },
        "credentials_allowed": {
          "const": false
        }
      }
    },
    "required_attestations": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "allOf": [
        {
          "contains": {
            "const": "no_live_targets"
          }
        },
        {
          "contains": {
            "const": "no_live_target_data_included"
          }
        },
        {
          "contains": {
            "const": "no_payloads"
          }
        },
        {
          "contains": {
            "const": "no_credentials"
          }
        },
        {
          "contains": {
            "const": "no_raw_scraper_text"
          }
        },
        {
          "contains": {
            "const": "no_private_hostnames"
          }
        }
      ]
    },
    "allowed_source_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,120}$"
      }
    },
    "allowed_sandbox_profiles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,120}$"
      }
    },
    "allowed_integration_exports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "splunk_saved_search",
          "elastic_detection_rule",
          "sentinel_analytic_rule",
          "jira_ticket",
          "servicenow_task",
          "operator_audit_event"
        ]
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_outputs_max_days",
        "audit_log_max_days",
        "customer_metadata_max_days",
        "raw_collection_retained",
        "deletion_review_required"
      ],
      "properties": {
        "runtime_outputs_max_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        },
        "audit_log_max_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "customer_metadata_max_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        },
        "raw_collection_retained": {
          "const": false
        },
        "deletion_review_required": {
          "const": true
        }
      }
    },
    "default_outputs": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(assets|world-side|cyber-side|evidence|integrations)/outputs/runtime/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\r\\n]+$"
      }
    }
  }
}
