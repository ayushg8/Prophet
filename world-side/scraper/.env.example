# world-side/scraper/.env.example
#
# Copy this to .env.local and fill in real values.
# .env.local is gitignored — it must NEVER be committed.

# --- SSH connection to the scraper machine ---
# These also live in ~/.ssh/config; this file is for scripts that
# read env vars instead of going through ssh config.
SCRAPER_HOST=
SCRAPER_USER=
SCRAPER_PORT=22
SCRAPER_KEY_PATH=~/.ssh/prophet_scraper_ed25519

# --- Paths ---
# Where the scraper writes output on its OWN disk
SCRAPER_OUTPUT_DIR=/srv/scraper/output

# Where rsync lands sanitized output on the MAIN dev box
LOCAL_INCOMING_DIR=./world-side/data/chatter/incoming

# --- Optional context APIs ---
# World Monitor is disabled in the checked-in catalog until a key is obtained
# out-of-band and Idan/Ayush approve the sanitizer for that payload.
WORLDMONITOR_API_KEY=
